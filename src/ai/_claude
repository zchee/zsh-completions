_claude__message() {
  _message "${1:-value}"
}

_claude__prompt_text() {
  _claude__message 'prompt text'
}

_claude__shift_words() {
  local shift_count=$1
  local -a shifted
  local index

  shifted=()
  for (( index = shift_count + 1; index <= ${#words}; index++ )); do
    shifted+=("${words[index]}")
  done

  reply=("${shifted[@]}")
  REPLY=$(( CURRENT - shift_count ))
  (( REPLY < 1 )) && REPLY=1
}

