function _claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args
  local -a specs

  _claude__top_option_specs
  specs=("${reply[@]}")

  _arguments -C -s \
    ${specs[@]} \
    '1:claude command:->command' \
    '*::claude argument:->args'

  case $state in
    command)
      _claude__top_commands
      return
      ;;
    args)
      case $words[1] in
        agents)
          _claude__complete_agents
          ;;
        auth)
          _claude__complete_auth
          ;;
        auto-mode)
          _claude__complete_auto_mode
          ;;
        doctor|setup-token|update|upgrade)
          _claude__complete_top_help_leaf
          ;;
        gateway)
          _claude__complete_gateway
          ;;
        import-conversations)
          _claude__complete_import_conversations
          ;;
        install)
          _claude__complete_install
          ;;
        mcp)
          _claude__complete_mcp
          ;;
        plugin|plugins)
          _claude__complete_plugin
          ;;
        project)
          _claude__complete_project
          ;;
        rc|remote-control)
          _claude__complete_remote_control
          ;;
        ultrareview)
          _claude__complete_ultrareview
          ;;
        *)
          _arguments -s '*::prompt:_claude__prompt_text'
          ;;
      esac
      ;;
  esac
}

_claude "$@"

