_claude__complete_auth() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C -s \
    '(-h --help)'{-h,--help}'[display help for command]' \
    '1:auth command:->command' \
    '*::auth argument:->args'

  case $state in
    command)
      _claude__auth_commands
      return
      ;;
  esac

  case $words[1] in
    login)
      _claude__shift_words 1
      words=("${reply[@]}")
      CURRENT=$REPLY
      _arguments -s \
        '(--claudeai --console)--claudeai[use Claude subscription]' \
        '(--claudeai --console)--console[use Anthropic Console instead of Claude subscription]' \
        '--email=[pre-populate email address on the login page]:email:_claude__message' \
        '--sso[force SSO login flow]' \
        '(-h --help)'{-h,--help}'[display help for command]'
      ;;
    logout)
      _claude__complete_help_only_leaf 1
      ;;
    status)
      _claude__shift_words 1
      words=("${reply[@]}")
      CURRENT=$REPLY
      _arguments -s \
        '(--json --text)--json[output as JSON]' \
        '(--json --text)--text[output as human-readable text]' \
        '(-h --help)'{-h,--help}'[display help for command]'
      ;;
    help)
      _claude__shift_words 1
      words=("${reply[@]}")
      CURRENT=$REPLY
      _arguments -s \
        '1:auth command:_claude__auth_commands' \
        '(-h --help)'{-h,--help}'[display help for command]'
      ;;
  esac
}

