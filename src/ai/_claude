_claude__complete_mcp() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C -s \
    '(-h --help)'{-h,--help}'[display help for command]' \
    '1:mcp command:->command' \
    '*::mcp argument:->args'

  case $state in
    command)
      _claude__mcp_commands
      return
      ;;
  esac

  case $words[1] in
    add)
      _claude__shift_words 1
      words=("${reply[@]}")
      CURRENT=$REPLY
      if (( CURRENT > 1 )); then
        case $words[$(( CURRENT - 1 ))] in
          (-t|--transport)
            _claude__mcp_transports
            return
            ;;
          (-s|--scope)
            _claude__scopes
            return
            ;;
          (--callback-port)
            _claude__message 'port'
            return
            ;;
          (--client-id)
            _claude__message 'client id'
            return
            ;;
          (--client-secret)
            return
            ;;
          (-e|--env)
            _claude__message 'env'
            return
            ;;
          (-H|--header)
            _claude__message 'header'
            return
            ;;
        esac
      fi
      _arguments -C -s \
        '--callback-port=[fixed port for OAuth callback]:port:_claude__message' \
        '--client-id=[OAuth client ID for HTTP/SSE servers]:client id:_claude__message' \
        '--client-secret[prompt for OAuth client secret]' \
        '(-e --env)'{-e,--env}'[set environment variables]:env:_claude__message' \
        '(-H --header)'{-H,--header}'[set WebSocket headers]:header:_claude__message' \
        '(-h --help)'{-h,--help}'[display help for command]' \
        '(-s --scope)'{-s,--scope}'[configuration scope]:scope:_claude__scopes' \
        '(-t --transport)'{-t,--transport}'[transport type]:transport:_claude__mcp_transports' \
        '--xaa[(hidden) enable XAA (SEP-990) for this server]' \
        '1:server name:_claude__message' \
        '2:command or URL:_claude__message' \
        '*::server argument:_normal'
      ;;
    add-from-claude-desktop)
      _claude__shift_words 1
      words=("${reply[@]}")
      CURRENT=$REPLY
      _arguments -s \
        '(-s --scope)'{-s,--scope}'[configuration scope]:scope:_claude__scopes' \
        '(-h --help)'{-h,--help}'[display help for command]'
      ;;
    add-json)
      _claude__shift_words 1
      words=("${reply[@]}")
      CURRENT=$REPLY
      _arguments -C -s \
        '--client-secret[prompt for OAuth client secret]' \
        '(-h --help)'{-h,--help}'[display help for command]' \
        '(-s --scope)'{-s,--scope}'[configuration scope]:scope:_claude__scopes' \
        '1:server name:_claude__message' \
        '2:JSON string:_claude__message'
      ;;
    get)
      _claude__shift_words 1
      words=("${reply[@]}")
