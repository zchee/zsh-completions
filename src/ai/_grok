(( $+functions[_grok_models] )) ||
_grok_models() {
    setopt localoptions extended_glob
    local -a models
    local line trimmed id
    for line in ${(f)"$(_call_program models grok models 2>/dev/null)"}; do
        trimmed=${line##[[:space:]]#}
        [[ $trimmed == ('* '|'- ')* ]] || continue
        trimmed=${trimmed#[*-] }
        id=${trimmed%% *}
        [[ -n $id ]] || continue
        if [[ $trimmed == *'(default)'* ]]; then
            models+=("$id:default model")
        else
            models+=("$id")
        fi
    done
    (( $#models )) || return 1
    _describe -t models 'model' models "$@"
}
