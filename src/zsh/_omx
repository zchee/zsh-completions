        '--tail-lines[set pane tail capture size]:line count:_omx__team_tail_lines' \
        '--tail-lines=[set pane tail capture size]:line count:_omx__team_tail_lines' \
        '(-h --help)'{-h,--help}'[show help]'
      ;;
    await)
      _arguments -s \
        '1:team name:_omx__team_names' \
        '--timeout-ms[set wait timeout in milliseconds]:milliseconds:_omx__message' \
        '--timeout-ms=[set wait timeout in milliseconds]:milliseconds:_omx__message' \
        '--after-event-id[resume waiting after a specific event id]:event id:_omx__message' \
        '--after-event-id=[resume waiting after a specific event id]:event id:_omx__message' \
        '--json[emit structured JSON]' \
        '(-h --help)'{-h,--help}'[show help]'
      ;;
    resume)
      _arguments -s \
        '1:team name:_omx__team_names' \
        '(-h --help)'{-h,--help}'[show help]'
      ;;
    shutdown)
      _arguments -s \
        '1:team name:_omx__team_names' \
        '--force[force the shutdown]' \
        '(-h --help)'{-h,--help}'[show help]'
      ;;
    api)
      _omx__complete_team_api
      ;;
    help|-h|--help)
      _omx__team_subcommands
      ;;
    *)
      if [[ $words[1] == <->:* ]]; then
        _arguments '*:task description:_omx__prompt_text'
      else
        _arguments \
          '1:worker-count and role or task text:_omx__team_allocation' \
          '*:task description:_omx__prompt_text'
      fi
      ;;
  esac
}

_omx__complete_ralph() {
