_omx__git_branches() {
  local current_branch line name desc
  local -a lines branches

  command git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
    _message 'git branch'
    return
  }

  current_branch=$(command git symbolic-ref --quiet --short HEAD 2>/dev/null)
  lines=("${(@f)$(command git for-each-ref --format='%(refname:short)%09%(refname)' refs/heads refs/remotes 2>/dev/null)}")
  branches=()

  for line in "${lines[@]}"; do
    name="${line%%$'\t'*}"
    [[ -n $name && $name != */HEAD ]] || continue

    if [[ ${line#*$'\t'} == refs/heads/* ]]; then
      desc='local branch'
      [[ $name == $current_branch ]] && desc='current branch'
    else
      desc='remote branch'
    fi

    branches+=("${name}:${desc}")
  done

  if (( $#branches )); then
    _describe 'git branch' branches
  else
    _message 'git branch'
  fi
}

_omx__git_commits() {
  local line sha subject
  local -a lines commits

  command git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
    _message 'commit SHA'
    return
  }

  lines=("${(@f)$(command git log --pretty=format:'%h%x09%s' -n 30 --no-show-signature 2>/dev/null)}")
  commits=()

  for line in "${lines[@]}"; do
    sha="${line%%$'\t'*}"
    subject="${line#*$'\t'}"
    [[ -n $sha ]] || continue
    subject="${subject//:/ - }"
    commits+=("${sha}:${subject}")
  done

  if (( $#commits )); then
    _describe 'commit SHA' commits
  else
    _message 'commit SHA'
  fi
}

_omx__team_api_current_operation() {
  local word

  for word in "${words[@]}"; do
    [[ -n $word && $word != -* ]] || continue
    REPLY=$word
    return
  done

  REPLY=''
}

_omx__team_api_json_input() {
  local operation skeleton

  _omx__team_api_current_operation
  operation=$REPLY

  case $operation in
    send-message)
      skeleton='{"team_name":"my-team","from_worker":"worker-1","to_worker":"leader-fixed","body":"ACK"}'
      ;;
    broadcast)
      skeleton='{"team_name":"my-team","from_worker":"leader-fixed","body":"status update","workers":["worker-1","worker-2"]}'
      ;;
    mailbox-list)
      skeleton='{"team_name":"my-team","worker":"worker-1"}'
      ;;
    mailbox-mark-delivered|mailbox-mark-notified)
      skeleton='{"team_name":"my-team","worker":"worker-1","message_id":"msg-123"}'
      ;;
    create-task)
      skeleton='{"team_name":"my-team","subject":"Investigate failure","description":"..."}'
      ;;
    read-task)
      skeleton='{"team_name":"my-team","task_id":"1"}'
      ;;
    list-tasks|get-summary|cleanup|orphan-cleanup|read-config|read-manifest|read-idle-state|read-stall-state)
      skeleton='{"team_name":"my-team"}'
      ;;
    update-task)
      skeleton='{"team_name":"my-team","task_id":"1","patch":{"summary":"..."}}'
      ;;
    claim-task)
      skeleton='{"team_name":"my-team","task_id":"1","worker":"worker-1"}'
      ;;
    transition-task-status)
      skeleton='{"team_name":"my-team","task_id":"1","from":"in_progress","to":"completed","claim_token":"claim-token"}'
      ;;
    release-task-claim)
      skeleton='{"team_name":"my-team","task_id":"1","claim_token":"claim-token"}'
      ;;
    read-worker-status|read-worker-heartbeat|write-worker-inbox|write-worker-identity|read-shutdown-ack)
      skeleton='{"team_name":"my-team","worker":"worker-1"}'
      ;;
    update-worker-heartbeat)
      skeleton='{"team_name":"my-team","worker":"worker-1","state":"busy"}'
      ;;
    append-event)
      skeleton='{"team_name":"my-team","event":{"type":"note","message":"..."}}'
      ;;
    read-events)
      skeleton='{"team_name":"my-team","limit":20}'
      ;;
    await-event)
      skeleton='{"team_name":"my-team","after_event_id":"evt-123","timeout_ms":30000}'
      ;;
    write-shutdown-request)
      skeleton='{"team_name":"my-team","from_worker":"leader-fixed","reason":"completed"}'
      ;;
    read-monitor-snapshot)
      skeleton='{"team_name":"my-team"}'
      ;;
    write-monitor-snapshot)
      skeleton='{"team_name":"my-team","snapshot":{"status":"ok"}}'
      ;;
    read-task-approval)
      skeleton='{"team_name":"my-team","task_id":"1"}'
      ;;
    write-task-approval)
      skeleton='{"team_name":"my-team","task_id":"1","approved":true}'
      ;;
    *)
      _message 'JSON object'
      return
      ;;
  esac

  compadd -Q -S '' -- "$skeleton"
}

_omx__team_allocation() {
  local -a roles suggestions
  local role count

  _omx__collect_prompt_roles
  roles=("${reply[@]}")

  if [[ $PREFIX == <->:* ]]; then
    count="${PREFIX%%:*}"
    suggestions=()
    for role in "${roles[@]}"; do
      suggestions+=("${count}:${role}")
    done
    compadd -Q -S '' -- "${suggestions[@]}"
    return
  fi

  suggestions=(
    "1:executor"
    "2:executor"
    "3:executor"
    "3:test-engineer"
    "4:architect"
  )
  _describe 'worker-count:agent-type' suggestions
}

