_omx__collect_autoresearch_run_ids() {
  local -a manifests run_ids
  local manifest

  manifests=(
    .omx/logs/autoresearch/*/manifest.json(N)
    .omx/logs/autoresearch/*/*/manifest.json(N)
  )

  run_ids=()
  for manifest in "${manifests[@]}"; do
    run_ids+=("${manifest:h:t}")
  done

  reply=(${(ou)run_ids})
}

_omx__autoresearch_run_ids() {
  local -a run_ids

  _omx__collect_autoresearch_run_ids
  run_ids=("${reply[@]}")

  if (( $#run_ids )); then
    _describe 'autoresearch run id' run_ids
  else
    _message 'run id'
  fi
}

_omx__team_allocation() {
  local -a roles suggestions
  local role count

  _omx__collect_prompt_roles
  roles=("${reply[@]}")

  if [[ $PREFIX == <->:* ]]; then
    count="${PREFIX%%:*}"
    suggestions=()
    for role in "${roles[@]}"; do
      suggestions+=("${count}:${role}")
    done
    compadd -Q -S '' -- "${suggestions[@]}"
    return
  fi

  suggestions=(
    "1:executor"
    "2:executor"
    "3:executor"
    "3:test-engineer"
    "4:architect"
  )
  _describe 'worker-count:agent-type' suggestions
}

