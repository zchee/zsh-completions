_omx__complete_root() {
  local curcontext="$curcontext" state line
  typeset -A opt_args
  local -a omx_specs codex_specs

  _omx__omx_wrapper_option_specs
  omx_specs=("${reply[@]}")
  _omx__codex_launch_option_specs
  codex_specs=("${reply[@]}")

  _arguments -C -s \
    ${omx_specs[@]} \
    ${codex_specs[@]} \
    '1:omx command:->command' \
    '*::launch argument:_omx__prompt_text'

  case $state in
    command)
      _omx__top_commands
      ;;
  esac
}

_omx__complete_launch_like() {
  local shift_count=${1:-0}
  local -a omx_specs codex_specs
