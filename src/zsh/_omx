_omx__complete_agents() {
  _omx__shift_words 1

  if (( CURRENT == 1 )); then
    _omx__agents_subcommands
    return
  fi

  case $words[1] in
    list)
      _arguments -s \
        '--scope[restrict to a specific scope]:scope:_omx__scope_values' \
        '(-h --help)'{-h,--help}'[show help]'
      ;;
    add)
      _arguments -s \
        '--scope[choose the mutation scope]:scope:_omx__scope_values' \
        '--force[overwrite an existing agent file]' \
        '1:agent name:_omx__message "new agent name"' \
        '(-h --help)'{-h,--help}'[show help]'
      ;;
    edit)
      _arguments -s \
        '--scope[restrict lookup to a specific scope]:scope:_omx__scope_values' \
        '1:agent name:_omx__native_agent_names' \
        '(-h --help)'{-h,--help}'[show help]'
      ;;
    remove)
      _arguments -s \
        '--scope[restrict lookup to a specific scope]:scope:_omx__scope_values' \
        '--force[skip the confirmation prompt]' \
        '1:agent name:_omx__native_agent_names' \
        '(-h --help)'{-h,--help}'[show help]'
      ;;
    help|-h|--help)
      _omx__agents_subcommands
      ;;
    *)
      _omx__agents_subcommands
      ;;
  esac
}

