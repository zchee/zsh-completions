_omx__complete_autoresearch() {
  local -a exec_specs
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _omx__shift_words 1
  _omx__codex_exec_option_specs
  exec_specs=("${reply[@]}")

  if (( CURRENT == 1 )); then
    _alternative \
      'subcommands:autoresearch mode:(init run help)' \
      'missions:mission directory:_omx__mission_dirs' \
      'options:guided flags:(--resume --topic --evaluator --keep-policy --slug --help -h)'
    return
  fi

  case $words[1] in
    init)
      _arguments -s \
        '--topic[seed the research topic]:topic:_omx__prompt_text' \
        '--topic=[seed the research topic]:topic:_omx__prompt_text' \
        '--evaluator[seed the evaluator command]:command:_omx__prompt_text' \
        '--evaluator=[seed the evaluator command]:command:_omx__prompt_text' \
        '--keep-policy[set the keep policy]:policy:_omx__keep_policies' \
        '--keep-policy=[set the keep policy]:policy:_omx__keep_policies' \
        '--slug[set the mission slug]:slug:_omx__message' \
        '--slug=[set the mission slug]:slug:_omx__message' \
        '(-h --help)'{-h,--help}'[show help]'
      ;;
    run)
      if (( CURRENT == 2 )); then
        _omx__mission_dirs
        return
      fi

      _arguments -C -s \
        '1:mission directory:_omx__mission_dirs' \
        ${exec_specs[@]} \
        '*::codex exec argument:_omx__prompt_text'
      ;;
    help|-h|--help)
      _values 'autoresearch mode' init run help
      ;;
    --resume)
      if (( CURRENT == 2 )); then
        _omx__autoresearch_run_ids
        return
      fi

      _arguments -C -s \
        '1:run id:_omx__autoresearch_run_ids' \
        ${exec_specs[@]} \
        '*::codex exec argument:_omx__prompt_text'
      ;;
    --resume=*)
      _arguments -C -s \
        ${exec_specs[@]} \
        '*::codex exec argument:_omx__prompt_text'
      ;;
    --topic|--evaluator|--keep-policy|--slug|--topic=*|--evaluator=*|--keep-policy=*|--slug=*)
      _arguments -s \
        '--topic[seed the research topic]:topic:_omx__prompt_text' \
        '--topic=[seed the research topic]:topic:_omx__prompt_text' \
        '--evaluator[seed the evaluator command]:command:_omx__prompt_text' \
        '--evaluator=[seed the evaluator command]:command:_omx__prompt_text' \
        '--keep-policy[set the keep policy]:policy:_omx__keep_policies' \
        '--keep-policy=[set the keep policy]:policy:_omx__keep_policies' \
        '--slug[set the mission slug]:slug:_omx__message' \
        '--slug=[set the mission slug]:slug:_omx__message' \
        '(-h --help)'{-h,--help}'[show help]'
      ;;
    *)
      if (( CURRENT == 1 )); then
        _omx__mission_dirs
        return
      fi

      _arguments -C -s \
        '1:mission directory:_omx__mission_dirs' \
        ${exec_specs[@]} \
        '*::codex exec argument:_omx__prompt_text'
      ;;
  esac
}

