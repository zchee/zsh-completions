_omx__complete_sparkshell() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _omx__shift_words 1

  if (( CURRENT == 1 )); then
    _alternative \
      'options:tmux pane mode:(--tmux-pane)' \
      'commands:command:_command_names -e'
    return
  fi

  if [[ $words[1] == --tmux-pane || $words[1] == --tmux-pane=* || $words[1] == --tail-lines || $words[1] == --tail-lines=* ]]; then
    _arguments -s \
      '--tmux-pane[read from a tmux pane id]:pane id:_omx__message' \
      '--tmux-pane=[read from a tmux pane id]:pane id:_omx__message' \
      '--tail-lines[capture between 100 and 1000 lines]:line count:_omx__team_tail_lines' \
      '--tail-lines=[capture between 100 and 1000 lines]:line count:_omx__team_tail_lines' \
      '(-h --help)'{-h,--help}'[show help]'
    return
  fi

  if (( CURRENT == 1 )); then
    _command_names -e
    return
  fi

  _default
}

