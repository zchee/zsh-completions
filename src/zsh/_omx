function _omx() {
  case $words[2] in
    '')
      _omx__complete_root
      ;;
    launch)
      _omx__complete_launch_like 1
      ;;
    exec)
      _omx__complete_exec
      ;;
    setup)
      _omx__complete_setup
      ;;
    agents)
      _omx__complete_agents
      ;;
    agents-init|deepinit)
      _omx__complete_agents_init
      ;;
    uninstall)
      _omx__complete_uninstall
      ;;
    doctor)
      _omx__complete_doctor
      ;;
    cleanup)
      _omx__complete_cleanup
      ;;
    ask)
      _omx__complete_ask
      ;;
    autoresearch)
      _omx__complete_autoresearch
      ;;
    explore)
      _omx__complete_explore
      ;;
    sparkshell)
      _omx__complete_sparkshell
      ;;
    team)
      _omx__complete_team
      ;;
    ralph)
      _omx__complete_ralph
      ;;
    session)
      _omx__complete_session
      ;;
    resume)
      _omx__complete_resume
      ;;
    version)
      _arguments '(-h --help)'{-h,--help}'[show help]'
      ;;
    tmux-hook)
      _omx__complete_tmux_hook
      ;;
    hooks)
      _omx__complete_hooks
      ;;
    hud)
      _omx__complete_hud
      ;;
    status|cancel)
      _arguments '(-h --help)'{-h,--help}'[show help]'
      ;;
    reasoning)
      _omx__complete_reasoning
      ;;
    help|-h|--help)
      _omx__complete_help
      ;;
    *)
      _omx__complete_root
      ;;
  esac
}

_omx "$@"

