_omx__collect_mission_dirs() {
  local -a paths names
  local path

  paths=(missions/*(/N))
  names=()
  for path in "${paths[@]}"; do
    [[ -f $path/mission.md && -f $path/sandbox.md ]] || continue
    names+=("${path:t}")
  done

  reply=(${(ou)names})
}

