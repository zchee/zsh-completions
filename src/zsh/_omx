_omx__message() {
  _message "${1:-value}"
}

_omx__shift_words() {
  local shift_count=$1
  local -a shifted
  local index

  shifted=()
  for (( index = shift_count + 1; index <= ${#words}; index++ )); do
    shifted+=("${words[index]}")
  done

  reply=("${shifted[@]}")
  REPLY=$(( CURRENT - shift_count ))
  (( REPLY < 1 )) && REPLY=1
}

_omx__collect_prompt_roles() {
  local -a dirs files roles
  local dir file

  dirs=(
    "./prompts"
    "./.codex/prompts"
    "${CODEX_HOME:-$HOME/.codex}/prompts"
    "/opt/local/var/bun/install/global/node_modules/oh-my-codex/prompts"
  )

  roles=()
  for dir in "${dirs[@]}"; do
    [[ -d $dir ]] || continue
    files=($dir/*.md(N))
    for file in "${files[@]}"; do
      roles+=("${file:t:r}")
    done
  done

  if (( ! $#roles )); then
    roles=(
      analyst architect build-fixer code-simplifier critic debugger
      default designer executor explorer planner researcher
      security-reviewer team-executor test-engineer verifier worker
      writer
    )
  fi

  reply=(${(ou)roles})
}

_omx__prompt_roles() {
  local -a roles

  _omx__collect_prompt_roles
  roles=("${reply[@]}")
  _describe 'role' roles
}

_omx__collect_native_agent_names() {
  local -a dirs files names
  local dir file

  dirs=(
    "./.codex/agents"
    "${CODEX_HOME:-$HOME/.codex}/agents"
  )

  names=()
  for dir in "${dirs[@]}"; do
    [[ -d $dir ]] || continue
    files=($dir/*.toml(N))
    for file in "${files[@]}"; do
      names+=("${file:t:r}")
    done
  done

  reply=(${(ou)names})
}

_omx__native_agent_names() {
