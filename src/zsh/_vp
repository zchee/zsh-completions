_vp_exec_commands() {
  local root dir bin
  local -a bins
  typeset -A seen

  root=$(_vp_find_workspace_root)
  dir=$PWD

  while [[ -n $dir ]]; do
    if [[ -d $dir/node_modules/.bin ]]; then
      for bin in $dir/node_modules/.bin/*(N:t); do
        seen[$bin]=1
      done
    fi

    [[ $dir == $root || $dir == / ]] && break
    dir=${dir:h}
  done

  bins=(${(ok)seen})
  if (( $#bins )); then
    _describe 'local executable' bins
    return 0
  fi

  _command_names
}

_vp_find_workspace_root() {
  local dir=$PWD
  local best=
  local nearest_pkg=
  local content

  while [[ -n $dir ]]; do
    if [[ -f $dir/package.json && -z $nearest_pkg ]]; then
      nearest_pkg=$dir
    fi

    if [[ -f $dir/pnpm-workspace.yaml || -f $dir/pnpm-lock.yaml || -f $dir/.pnpmfile.cjs || -f $dir/pnpmfile.cjs || -f $dir/yarn.lock || -f $dir/package-lock.json || -f $dir/.yarnrc.yml || -f $dir/yarn.config.cjs || -f $dir/bun.lock || -f $dir/bun.lockb ]]; then
      best=$dir
    elif [[ -f $dir/package.json ]]; then
      if _vp_package_manager_from_file "$dir/package.json" >/dev/null; then
        best=$dir
      else
        content=$(_vp_package_json_content "$dir/package.json")
        if [[ $content == *'"workspaces"'* ]]; then
          best=$dir
        fi
      fi
    fi

    [[ $dir == / ]] && break
    dir=${dir:h}
  done

  if [[ -n $best ]]; then
    print -r -- $best
    return 0
  fi
  if [[ -n $nearest_pkg ]]; then
    print -r -- $nearest_pkg
    return 0
  fi

  return 1
}

