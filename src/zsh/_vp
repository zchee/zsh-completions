_vp_detect_package_manager() {
  local dir content after root

  root=$(_vp_find_workspace_root)
  dir=$root

  while [[ -n $dir ]]; do
    if [[ -f $dir/package.json ]]; then
      content=$(<"$dir/package.json")
      content=${content//$'\n'/ }
      content=${content//$'\r'/ }
      content=${content//$'\t'/ }

      if [[ $content == *'"packageManager"'* ]]; then
        after=${content#*\"packageManager\"}
        after=${after#*:}
        after=${after#${after%%[![:space:]]*}}

        if [[ $after == \"* ]]; then
          after=${after#\"}
          after=${after%%\"*}
          print -r -- ${after%%@*}
          return 0
        fi
      fi
    fi

    [[ $dir == / ]] && break
    dir=${dir:h}
  done

  dir=$root
  while [[ -n $dir ]]; do
    if [[ -f $dir/pnpm-workspace.yaml || -f $dir/pnpm-lock.yaml || -f $dir/.pnpmfile.cjs || -f $dir/pnpmfile.cjs ]]; then
      print -r -- pnpm
      return 0
    fi
    if [[ -f $dir/yarn.lock || -f $dir/.yarnrc.yml || -f $dir/yarn.config.cjs ]]; then
      print -r -- yarn
      return 0
    fi
    if [[ -f $dir/package-lock.json ]]; then
      print -r -- npm
      return 0
    fi
    if [[ -f $dir/bun.lock || -f $dir/bun.lockb ]]; then
      print -r -- bun
      return 0
    fi

    [[ $dir == / ]] && break
    dir=${dir:h}
  done

  print -r -- pnpm
}

