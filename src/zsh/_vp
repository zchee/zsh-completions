function _vp() {
  local context curcontext=$curcontext state line expl ret=1
  declare -A opt_args

  local -a commands top_flags command_help_flags vite_common_flags test_common_flags
  local -a dependency_filter_flags dependency_scope_flags dependency_tree_output_flags

  _vp_commands
  commands=("${reply[@]}")

  top_flags=(
    {-h,--help}"[Print help]"
    {-V,--version}"[Print version]"
  )

  command_help_flags=(
    {-h,--help}"[Show this help message]"
  )

  dependency_filter_flags=(
    '*--filter[Filter packages in monorepo]:pattern'
  )

  dependency_scope_flags=(
    {-P,--prod}"[Only production dependencies]"
    {-D,--dev}"[Only dev dependencies]"
    '--no-optional[Exclude optional dependencies]'
  )

  dependency_tree_output_flags=(
    '--json[Output in JSON format]'
    '--long[Show extended information]'
    '--parseable[Parseable output format]'
  )

  vite_common_flags=(
    "--base[Public base path]:path"
    {-c,--config}"[Use specified config file]:file:_files"
    {-l,--logLevel}"[Set log level]:level:_vp_log_levels"
    "--clearScreen[Allow or disable clear screen when logging]"
    "--configLoader[Use the selected config loader]:loader:_vp_vite_config_loaders"
    {-d,--debug}"[Show debug logs]::feature"
    {-f,--filter}"[Filter debug logs]:filter"
    {-m,--mode}"[Set env mode]:mode"
    {-h,--help}"[Display this message]"
  )

  test_common_flags=(
    {-r,--root}"[Root path]:path:_directories"
    {-c,--config}"[Path to config file]:path:_files"
    {-u,--update}"[Update snapshot]::type:_vp_test_update_modes"
    {-v,--version}"[Display version number]"
    {-w,--watch}"[Enable watch mode]"
    {-t,--testNamePattern}"[Run tests with full names matching the specified pattern]:pattern"
    "--dir[Base directory to scan for test files]:path:_directories"
    "--ui[Enable UI]"
    "--open[Open UI automatically]"
    "--api[Specify API server port]::port:_ports"
    "--silent[Control console output]::mode:_vp_test_silent_modes"
    "--hideSkippedTests[Hide logs for skipped tests]"
    "*--reporter[Specify reporter]:name:_vp_test_reporters"
    "--outputFile[Write test results to a file]:file:_files"
    "--coverage[Enable coverage report]"
    "--mode[Override Vite mode]:name"
    "--isolate[Run every test file in isolation]"
    "--no-isolate[Disable test-file isolation]"
    "--globals[Inject APIs globally]"
    "--dom[Mock browser APIs with happy-dom]"
    "--browser[Run tests in the browser]:name:(playwright preview webdriverio)"
    "--pool[Specify worker pool]:pool:_vp_test_pools"
    "*--execArgv[Pass additional arguments to the node process]:option"
    "--vmMemoryLimit[Set VM memory limit]:limit"
    "--fileParallelism[Run all test files in parallel]"
    "--no-file-parallelism[Disable file parallelism]"
    "--maxWorkers[Maximum workers]:workers"
    "--environment[Specify runner environment]:name:_vp_test_environments"
    "--passWithNoTests[Pass when no tests are found]"
    "--logHeapUsage[Show heap size for each test]"
    "--detectAsyncLeaks[Detect leaked async resources]"
    "--allowOnly[Allow tests and suites marked as only]"
    "--dangerouslyIgnoreUnhandledErrors[Ignore unhandled errors]"
    "--shard[Test suite shard]:index/count"
    "--changed[Run tests affected by changed files]::since"
    "--sequence[Configure test sorting]:options"
    "--inspect[Enable Node.js inspector]::host:port"
    "--inspectBrk[Enable Node.js inspector and break before tests start]::host:port"
    "--testTimeout[Default test timeout in milliseconds]:timeout"
    "--hookTimeout[Default hook timeout in milliseconds]:timeout"
    "--bail[Stop after the given number of test failures]:number"
    "--retry[Retry failed tests this many times]:times"
    "--diff[Diff options object or module path]:path:_files"
    "*--exclude[Additional file globs to exclude]:glob"
    "--expandSnapshotDiff[Show full diff when snapshots fail]"
    "--disableConsoleIntercept[Disable automatic console interception]"
    "--typecheck[Enable type checking alongside tests]"
    "*--project[Select project by name]:name"
    "--slowTestThreshold[Slow test threshold in milliseconds]:threshold"
    "--teardownTimeout[Default teardown timeout in milliseconds]:timeout"
    "--cache[Enable cache]"
    "--maxConcurrency[Maximum concurrent tests and suites]:number"
    "--expect[Configure expect() matchers]:options"
    "--printConsoleTrace[Always print console stack traces]"
    "--includeTaskLocation[Collect task and suite locations]"
    "--attachmentsDir[Directory for test attachments]:dir:_directories"
    "--run[Disable watch mode]"
    "--no-color[Disable colors in output]"
    "--clearScreen[Clear terminal screen when re-running tests]"
    "--configLoader[Use the selected config loader]:loader:_vp_test_config_loaders"
    "--standalone[Start without running tests until files change]"
    "--mergeReports[Path to blob report directory]:path:_directories"
    "--listTags[List all available tags]::type:(json)"
    "--clearCache[Delete all Vitest caches without running tests]"
    "--tagsFilter[Run only tests matching the tag expression]:expression"
    "--strictTags[Error when tests use tags not defined in config]"
    "--experimental[Enable experimental features]:features"
    {-h,--help}"[Display this message]"
  )

  _arguments -C \
    $top_flags \
    '1:vp command:->command' \
    '*::vp argument:->args' \
    && ret=0

  case $state in
    command)
      _describe 'vp command' commands && ret=0
      ;;

    args)
      case $words[1] in
        create)
          _arguments \
            $command_help_flags \
            '--directory[Target directory for the generated project]:directory:_directories' \
            '--agent[Create an agent instructions file for the specified agent]:agent:_vp_agents' \
            '--editor[Write editor config files for the specified editor]:editor:_vp_editors' \
            '--hooks[Set up pre-commit hooks]' \
            '--no-hooks[Skip pre-commit hooks setup]' \
            '--verbose[Show detailed scaffolding output]' \
            '--no-interactive[Run in non-interactive mode]' \
            '--list[List all available templates]' \
            '1:template:_vp_create_templates' \
            '*::template option:_default' \
            && ret=0
          ;;

        migrate)
          _arguments \
            $command_help_flags \
            '--agent[Write agent instructions file into the project]:agent:_vp_agents' \
            '--no-agent[Skip writing agent instructions file]' \
            '--editor[Write editor config files into the project]:editor:_vp_editors' \
            '--no-editor[Skip writing editor config files]' \
            '--hooks[Set up pre-commit hooks]' \
            '--no-hooks[Skip pre-commit hooks setup]' \
            '--no-interactive[Run in non-interactive mode]' \
            '1:target directory:_directories' \
            && ret=0
          ;;

        config)
          _arguments \
            $command_help_flags \
            '--hooks-dir[Custom hooks directory]:path:_directories' \
            && ret=0
          ;;

        staged)
          _arguments \
            $command_help_flags \
            '--allow-empty[Allow empty commits when tasks revert all staged changes]' \
            {-p,--concurrent}"[Number of tasks to run concurrently, or false for serial]:count or boolean:(false true)" \
            '--continue-on-error[Run all tasks even if one fails]' \
            '--cwd[Working directory to run tasks in]:path:_directories' \
            {-d,--debug}"[Enable debug output]" \
            '--diff[Override the default --staged flag of git diff]:string' \
            '--diff-filter[Override the default --diff-filter=ACMR flag of git diff]:string' \
            '--fail-on-changes[Fail when tasks modify tracked files]' \
            '--hide-partially-staged[Hide unstaged changes from partially staged files]' \
            '--hide-unstaged[Hide all unstaged changes before running tasks]' \
            '--no-stash[Disable the backup stash]' \
            {-q,--quiet}"[Disable console output]" \
            {-r,--relative}"[Pass file paths relative to cwd to tasks]" \
            '--revert[Revert to the original state when errors occur]' \
            {-v,--verbose}"[Show task output even when tasks succeed]" \
            && ret=0
          ;;

        install|i)
          _vp_package_manager_completion && ret=0
          ;;

        env)
          if (( CURRENT == 2 )) && [[ $words[CURRENT] != -* ]]; then
            _vp_env_commands && ret=0
            return ret
          fi

          case $words[2] in
            setup)
              _arguments \
                $command_help_flags \
                '--refresh[Force refresh shims even if they already exist]' \
                '--env-only[Only create env files and skip shims and instructions]' \
                && ret=0
              ;;

            on|off|print|unpin|doctor)
              _arguments \
                $command_help_flags \
                && ret=0
              ;;

            default)
              _arguments \
                $command_help_flags \
                '1::version:_vp_env_versions' \
                && ret=0
              ;;

            pin)
              _arguments \
                $command_help_flags \
                '--unpin[Remove the .node-version file from the current directory]' \
                '--no-install[Skip pre-downloading the pinned version]' \
                '--force[Overwrite an existing .node-version without confirmation]' \
                '1::version:_vp_env_versions' \
                && ret=0
              ;;

            use)
              _arguments \
                $command_help_flags \
                '--unset[Remove the session override and revert to file-based resolution]' \
                '--no-install[Skip auto-installation if the version is not present]' \
                '--silent-if-unchanged[Suppress output if the requested version is already active]' \
                '1::version:_vp_env_versions' \
                && ret=0
              ;;

            install|i)
              _arguments \
                $command_help_flags \
                '1::version:_vp_env_versions' \
                && ret=0
              ;;

            uninstall|uni)
              _arguments \
                $command_help_flags \
                '1:version:_vp_env_installed_versions' \
                && ret=0
              ;;

            exec|run)
              _arguments \
                $command_help_flags \
                '--node[Node.js version to use]:version:_vp_env_versions' \
                '--npm[npm version to use]:version:_vp_env_npm_versions' \
                '1::command:_command_names' \
                '*::command argument:_default' \
                && ret=0
              ;;

            current)
              _arguments \
                $command_help_flags \
                '--json[Output in JSON format]' \
                && ret=0
              ;;

            which)
