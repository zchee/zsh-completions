_vp_package_json_content() {
  local file=$1
  local content

  [[ -f $file ]] || return 1

  content=$(<"$file")
  content=${content//$'\n'/ }
  content=${content//$'\r'/ }
  content=${content//$'\t'/ }

  print -r -- $content
}

_vp_package_manager_from_file() {
  local content after

  content=$(_vp_package_json_content "$1") || return 1
  [[ $content == *'"packageManager"'* ]] || return 1

  after=${content#*\"packageManager\"}
  after=${after#*:}
  after=${after#${after%%[![:space:]]*}}

  if [[ $after == \"* ]]; then
    after=${after#\"}
    after=${after%%\"*}
    print -r -- ${after%%@*}
    return 0
  fi

  return 1
}

_vp_detect_package_manager() {
  local root pm

  root=$(_vp_find_workspace_root)
  [[ -n $root ]] || {
    print -r -- pnpm
    return 0
  }

  pm=$(_vp_package_manager_from_file "$root/package.json")
  [[ -n $pm ]] && {
    print -r -- $pm
    return 0
  }

  if [[ -f $root/pnpm-workspace.yaml || -f $root/pnpm-lock.yaml || -f $root/.pnpmfile.cjs || -f $root/pnpmfile.cjs ]]; then
    print -r -- pnpm
    return 0
  fi
  if [[ -f $root/yarn.lock || -f $root/.yarnrc.yml || -f $root/yarn.config.cjs ]]; then
    print -r -- yarn
    return 0
  fi
  if [[ -f $root/package-lock.json ]]; then
    print -r -- npm
    return 0
  fi
  if [[ -f $root/bun.lock || -f $root/bun.lockb ]]; then
    print -r -- bun
    return 0
  fi

  print -r -- pnpm
}

