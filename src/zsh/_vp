_vp_package_manager_completion() {
  local fn pm ret=1

  pm=$(_vp_detect_package_manager)
  case $pm in
    pnpm) fn=_pnpm ;;
    npm) fn=_npm ;;
    yarn) fn=_yarn ;;
    bun) fn=_bun ;;
    *) fn= ;;
  esac

  if [[ -n $fn ]]; then
    autoload -Uz $fn 2>/dev/null
    _call_function ret $fn && return 0
  fi

  _message "package manager arguments"
  return 0
}

