_vp_exec_commands() {
  local root
  local -a bins

  root=$(_vp_find_workspace_root)
  if [[ -n $root && -d $root/node_modules/.bin ]]; then
    bins=( $root/node_modules/.bin/*(N:t) )
    if (( $#bins )); then
      _describe 'local executable' bins
      return 0
    fi
  fi

  _command_names
}

_vp_find_workspace_root() {
  local dir=$PWD

  while [[ -n $dir ]]; do
    if [[ -f $dir/package.json || -f $dir/pnpm-workspace.yaml || -f $dir/pnpm-lock.yaml || -f $dir/yarn.lock || -f $dir/package-lock.json || -f $dir/.yarnrc.yml || -f $dir/bun.lock || -f $dir/bun.lockb ]]; then
      print -r -- $dir
      return 0
    fi

    [[ $dir == / ]] && break
    dir=${dir:h}
  done

  return 1
}

