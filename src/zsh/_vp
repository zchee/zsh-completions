function _vp() {
  local context curcontext=$curcontext state line expl ret=1
  declare -A opt_args

  local -a commands top_flags command_help_flags vite_common_flags test_common_flags

  commands=(
    "create:Create a new project from a template"
    "migrate:Migrate an existing project to Vite+"
    "config:Configure hooks and agent integration"
    "staged:Run linters on staged files"
    "install:Install dependencies with the detected package manager"
    "i:Alias for install"
    "dev:Run the development server"
    "build:Build for production"
    "preview:Preview production build"
    "check:Run format, lint, and type checks"
    "lint:Lint code"
    "fmt:Format code"
    "test:Run tests"
    "run:Run tasks"
    "exec:Execute a local project binary"
    "cache:Manage the task cache"
    "pack:Build libraries or executables"
    "mcp:Start the Vite+ docs MCP server"
    "help:Show help for a command"
  )

  top_flags=(
    {-h,--help}"[Print help]"
    {-V,--version}"[Print version]"
  )

  command_help_flags=(
    {-h,--help}"[Show this help message]"
  )

  vite_common_flags=(
    "--base[Public base path]:path"
    {-c,--config}"[Use specified config file]:file:_files"
    {-l,--logLevel}"[Set log level]:level:_vp_log_levels"
    "--clearScreen[Allow or disable clear screen when logging]"
    "--configLoader[Use the selected config loader]:loader:_vp_vite_config_loaders"
    {-d,--debug}"[Show debug logs]::feature"
    {-f,--filter}"[Filter debug logs]:filter"
    {-m,--mode}"[Set env mode]:mode"
    {-h,--help}"[Display this message]"
  )

  test_common_flags=(
    {-r,--root}"[Root path]:path:_directories"
    {-c,--config}"[Path to config file]:path:_files"
    {-u,--update}"[Update snapshot]::type:_vp_test_update_modes"
    {-w,--watch}"[Enable watch mode]"
    {-t,--testNamePattern}"[Run tests with full names matching the specified pattern]:pattern"
    "--dir[Base directory to scan for test files]:path:_directories"
    "--ui[Enable UI]"
    "--open[Open UI automatically]"
    "--api[Specify API server port]::port:_ports"
    "--silent[Control console output]::mode:_vp_test_silent_modes"
    "--hideSkippedTests[Hide logs for skipped tests]"
    "*--reporter[Specify reporter]:name:_vp_test_reporters"
    "--outputFile[Write test results to a file]:file:_files"
    "--coverage[Enable coverage report]"
    "--mode[Override Vite mode]:name"
    "--isolate[Run every test file in isolation]"
    "--no-isolate[Disable test-file isolation]"
    "--globals[Inject APIs globally]"
    "--dom[Mock browser APIs with happy-dom]"
    "--browser[Run tests in the browser]:name:(playwright preview webdriverio)"
    "--pool[Specify worker pool]:pool:_vp_test_pools"
    "*--execArgv[Pass additional arguments to the node process]:option"
    "--vmMemoryLimit[Set VM memory limit]:limit"
    "--fileParallelism[Run all test files in parallel]"
    "--no-file-parallelism[Disable file parallelism]"
    "--maxWorkers[Maximum workers]:workers"
    "--environment[Specify runner environment]:name:_vp_test_environments"
    "--passWithNoTests[Pass when no tests are found]"
    "--logHeapUsage[Show heap size for each test]"
    "--detectAsyncLeaks[Detect leaked async resources]"
    "--allowOnly[Allow tests and suites marked as only]"
    "--dangerouslyIgnoreUnhandledErrors[Ignore unhandled errors]"
    "--shard[Test suite shard]:index/count"
    "--changed[Run tests affected by changed files]::since"
    "--sequence[Configure test sorting]:options"
    "--inspect[Enable Node.js inspector]::host:port"
    "--inspectBrk[Enable Node.js inspector and break before tests start]::host:port"
    "--testTimeout[Default test timeout in milliseconds]:timeout"
    "--hookTimeout[Default hook timeout in milliseconds]:timeout"
    "--bail[Stop after the given number of test failures]:number"
    "--retry[Retry failed tests this many times]:times"
    "--diff[Diff options object or module path]:path:_files"
    "*--exclude[Additional file globs to exclude]:glob"
    "--expandSnapshotDiff[Show full diff when snapshots fail]"
    "--disableConsoleIntercept[Disable automatic console interception]"
    "--typecheck[Enable type checking alongside tests]"
    "*--project[Select project by name]:name"
    "--slowTestThreshold[Slow test threshold in milliseconds]:threshold"
    "--teardownTimeout[Default teardown timeout in milliseconds]:timeout"
    "--cache[Enable cache]"
    "--maxConcurrency[Maximum concurrent tests and suites]:number"
    "--expect[Configure expect() matchers]:options"
    "--printConsoleTrace[Always print console stack traces]"
    "--includeTaskLocation[Collect task and suite locations]"
    "--attachmentsDir[Directory for test attachments]:dir:_directories"
    "--run[Disable watch mode]"
    "--no-color[Disable colors in output]"
    "--clearScreen[Clear terminal screen when re-running tests]"
    "--configLoader[Use the selected config loader]:loader:_vp_test_config_loaders"
    "--standalone[Start without running tests until files change]"
    "--mergeReports[Path to blob report directory]:path:_directories"
    "--listTags[List all available tags]::type:(json)"
    "--clearCache[Delete all Vitest caches without running tests]"
    "--tagsFilter[Run only tests matching the tag expression]:expression"
    "--strictTags[Error when tests use tags not defined in config]"
    "--experimental[Enable experimental features]:features"
    {-h,--help}"[Display this message]"
  )

  _arguments -C \
    $top_flags \
    '1:vp command:->command' \
    '*::vp argument:->args' \
    && ret=0

  case $state in
    command)
      _describe 'vp command' commands && ret=0
      ;;

    args)
      case $words[1] in
        create)
          _arguments \
            $command_help_flags \
            '--directory[Target directory for the generated project]:directory:_directories' \
            '--agent[Create an agent instructions file for the specified agent]:agent:_vp_agents' \
            '--editor[Write editor config files for the specified editor]:editor:_vp_editors' \
            '--hooks[Set up pre-commit hooks]' \
            '--no-hooks[Skip pre-commit hooks setup]' \
            '--verbose[Show detailed scaffolding output]' \
            '--no-interactive[Run in non-interactive mode]' \
            '--list[List all available templates]' \
            '1:template:_vp_create_templates' \
            '*::template option:_default' \
            && ret=0
          ;;

        migrate)
          _arguments \
            $command_help_flags \
            '--agent[Write agent instructions file into the project]:agent:_vp_agents' \
            '--no-agent[Skip writing agent instructions file]' \
            '--editor[Write editor config files into the project]:editor:_vp_editors' \
            '--no-editor[Skip writing editor config files]' \
            '--hooks[Set up pre-commit hooks]' \
            '--no-hooks[Skip pre-commit hooks setup]' \
            '--no-interactive[Run in non-interactive mode]' \
            '1:target directory:_directories' \
            && ret=0
          ;;

        config)
          _arguments \
            $command_help_flags \
            '--hooks-dir[Custom hooks directory]:path:_directories' \
            && ret=0
          ;;

        staged)
          _arguments \
            $command_help_flags \
            '--allow-empty[Allow empty commits when tasks revert all staged changes]' \
            {-p,--concurrent}"[Number of tasks to run concurrently, or false for serial]:count or boolean:(false true)" \
            '--continue-on-error[Run all tasks even if one fails]' \
            '--cwd[Working directory to run tasks in]:path:_directories' \
            {-d,--debug}"[Enable debug output]" \
            '--diff[Override the default --staged flag of git diff]:string' \
            '--diff-filter[Override the default --diff-filter=ACMR flag of git diff]:string' \
            '--fail-on-changes[Fail when tasks modify tracked files]' \
            '--hide-partially-staged[Hide unstaged changes from partially staged files]' \
            '--hide-unstaged[Hide all unstaged changes before running tasks]' \
            '--no-stash[Disable the backup stash]' \
            {-q,--quiet}"[Disable console output]" \
            {-r,--relative}"[Pass file paths relative to cwd to tasks]" \
            '--revert[Revert to the original state when errors occur]' \
            {-v,--verbose}"[Show task output even when tasks succeed]" \
            && ret=0
          ;;

        install|i)
          _vp_package_manager_completion && ret=0
          ;;

        dev)
          _arguments \
            '--host[Specify hostname]::hostname:_hostnames' \
            '--port[Specify port]:port:_ports' \
            '--open[Open browser on startup]::path:_files' \
            '--cors[Enable CORS]' \
            '--strictPort[Exit if the specified port is already in use]' \
            '--force[Force the optimizer to ignore the cache and re-bundle]' \
            '--experimentalBundle[Use experimental full bundle mode]' \
            $vite_common_flags \
            {-v,--version}"[Display version number]" \
            '1:root directory:_directories' \
            && ret=0
          ;;

        build)
          _arguments \
            '--target[Transpile target]:target:_vp_build_targets' \
            '--outDir[Output directory]:dir:_directories' \
            '--assetsDir[Directory under outDir to place assets in]:dir:_directories' \
            '--assetsInlineLimit[Static asset inline threshold in bytes]:bytes' \
            '--ssr[Build the specified entry for server-side rendering]::entry:_files' \
            '--sourcemap[Output source maps for build]::output:(inline hidden)' \
            '--minify[Enable or configure minification]::minifier:(terser esbuild)' \
            '--manifest[Emit build manifest json]::name:_files' \
            '--ssrManifest[Emit SSR manifest json]::name:_files' \
            '--emptyOutDir[Force empty outDir when it is outside of root]' \
            {-w,--watch}"[Rebuild when modules change on disk]" \
            '--app[Use application builder defaults]' \
            $vite_common_flags \
            '1:root directory:_directories' \
            && ret=0
          ;;

        preview)
          _arguments \
            '--host[Specify hostname]::hostname:_hostnames' \
            '--port[Specify port]:port:_ports' \
            '--strictPort[Exit if the specified port is already in use]' \
            '--open[Open browser on startup]::path:_files' \
            '--outDir[Output directory]:dir:_directories' \
            $vite_common_flags \
            {-v,--version}"[Display version number]" \
            '1:root directory:_directories' \
            && ret=0
          ;;

        check)
          _arguments \
            $command_help_flags \
            '--fix[Auto-fix format and lint issues]' \
            '--no-fmt[Skip format check]' \
            '--no-lint[Skip lint check]' \
            '*:path:_files' \
            && ret=0
          ;;

        lint)
          _arguments \
            {-c,--config}"[Oxlint configuration file]:config:_files" \
            '--tsconfig[Override the TypeScript config used for import resolution]:tsconfig:_files' \
            '--init[Initialize oxlint configuration with default values]' \
            {-A,--allow}"[Allow the rule or category]:rule or category:(correctness suspicious pedantic perf style restriction nursery all)" \
            {-W,--warn}"[Warn on the rule or category]:rule or category:(correctness suspicious pedantic perf style restriction nursery all)" \
            {-D,--deny}"[Deny the rule or category]:rule or category:(correctness suspicious pedantic perf style restriction nursery all)" \
            '--disable-unicorn-plugin[Disable the unicorn plugin]' \
            '--disable-oxc-plugin[Disable the oxc plugin]' \
            '--disable-typescript-plugin[Disable the TypeScript plugin]' \
            '--import-plugin[Enable the import plugin]' \
            '--react-plugin[Enable the react plugin]' \
            '--jsdoc-plugin[Enable the jsdoc plugin]' \
            '--jest-plugin[Enable the jest plugin]' \
            '--vitest-plugin[Enable the vitest plugin]' \
            '--jsx-a11y-plugin[Enable the JSX-a11y plugin]' \
            '--nextjs-plugin[Enable the Next.js plugin]' \
            '--react-perf-plugin[Enable the React performance plugin]' \
            '--promise-plugin[Enable the promise plugin]' \
            '--node-plugin[Enable the node plugin]' \
            '--vue-plugin[Enable the vue plugin]' \
            '--fix[Fix as many issues as possible]' \
            '--fix-suggestions[Apply auto-fixable suggestions]' \
            '--fix-dangerously[Apply dangerous fixes and suggestions]' \
            '--ignore-path[Specify the ignore file to use]:path:_files' \
            '--ignore-pattern[Specify additional patterns of files to ignore]:pattern' \
            '--no-ignore[Disable ignore files and ignore patterns]' \
            '--quiet[Disable reporting on warnings]' \
            '--deny-warnings[Ensure warnings produce a non-zero exit code]' \
            '--max-warnings[Warning threshold]:count' \
            {-f,--format}"[Use a specific output format]:format:(checkstyle default github gitlab json junit stylish unix)" \
            '--silent[Do not display diagnostics]' \
            '--threads[Number of threads to use]:count' \
            '--print-config[Output the configuration to be used]' \
            '--report-unused-disable-directives[Report unused disable directives]' \
            '--report-unused-disable-directives-severity[Severity for unused disable directives]:severity' \
            '--rules[List all currently registered rules]' \
            '--lsp[Start the language server]' \
            '--disable-nested-config[Disable nested configuration file loading]' \
            '--type-aware[Enable rules that require type information]' \
            '--type-check[Enable experimental type checking]' \
            {-h,--help}"[Print help information]" \
            {-V,--version}"[Print version information]" \
            '*:path:_files' \
            && ret=0
          ;;

        fmt)
          _arguments \
            '--init[Initialize .oxfmtrc.json with default values]' \
            '--migrate[Migrate configuration to .oxfmtrc.json]:source:_vp_format_migrate_sources' \
            '--lsp[Start language server protocol server]' \
            '--stdin-filepath[File name used to infer the parser]:path:_files' \
            '--write[Format and write files in place]' \
            '--check[Check if files are formatted]' \
            '--list-different[List files that would be changed]' \
            {-c,--config}"[Path to configuration file]:path:_files" \
            '*--ignore-path[Path to ignore file]:path:_files' \
            '--with-node-modules[Format files in node_modules]' \
            '--no-error-on-unmatched-pattern[Do not fail when a pattern matches no files]' \
            '--threads[Number of threads to use]:count' \
            {-h,--help}"[Print help information]" \
            {-V,--version}"[Print version information]" \
            '*:path:_files' \
            && ret=0
          ;;

        test)
          if (( CURRENT == 2 )) && [[ $words[CURRENT] != -* ]]; then
            _alternative \
              'commands:test command:_vp_test_commands' \
              'files:test filter:_files' \
              && ret=0
            return ret
          fi

          case $words[2] in
            run|related|watch|dev|list)
              _arguments \
                $test_common_flags \
                '*:filter:_files' \
                && ret=0
              ;;

            bench)
              _arguments \
                '--compare[Benchmark output file to compare against]:file:_files' \
                '--outputJson[Benchmark output file]:file:_files' \
                $test_common_flags \
                '*:filter:_files' \
                && ret=0
              ;;

            init)
              _arguments \
                $test_common_flags \
                '1:project directory:_directories' \
                && ret=0
              ;;

            complete)
              _arguments \
                $test_common_flags \
                '1:shell:_vp_test_shells' \
                && ret=0
              ;;

            *)
              _arguments \
                $test_common_flags \
                '*:filter:_files' \
                && ret=0
              ;;
          esac
          ;;

        run)
          _arguments \
            {-r,--recursive}"[Select all packages in the workspace]" \
            {-t,--transitive}"[Select the current package and its transitive dependencies]" \
            {-w,--workspace-root}"[Select the workspace root package]" \
            '*'{-F,--filter}"[Match packages by name, directory, or glob pattern]:filter" \
            '--ignore-depends-on[Do not run dependencies specified in dependsOn fields]' \
            {-v,--verbose}"[Show a full detailed summary after execution]" \
            '--cache[Force caching on for all tasks and scripts]' \
            '--no-cache[Force caching off for all tasks and scripts]' \
            '--log[Select how task output is displayed]:mode:_vp_run_logs' \
            '--last-details[Display the detailed summary of the last run]' \
            {-h,--help}"[Print help]" \
            '1:task specifier' \
            '*::additional argument:_default' \
            && ret=0
          ;;

        exec)
          if (( CURRENT == 2 )) && [[ $words[CURRENT] != -* ]]; then
            _vp_exec_commands && ret=0
            return ret
          fi

          _arguments \
            {-r,--recursive}"[Select all packages in the workspace]" \
            {-t,--transitive}"[Select the current package and its transitive dependencies]" \
            {-w,--workspace-root}"[Select the workspace root package]" \
            '*'{-F,--filter}"[Match packages by name, directory, or glob pattern]:filter" \
            {-c,--shell-mode}"[Execute the command within a shell environment]" \
            '--parallel[Run concurrently without topological ordering]' \
            '--reverse[Reverse execution order]' \
            '--resume-from[Resume from a specific package]:package' \
            '--report-summary[Save results to vp-exec-summary.json]' \
            {-h,--help}"[Print help]" \
            '*::command:_vp_exec_commands' \
            && ret=0
          ;;

        cache)
          if (( CURRENT == 2 )) && [[ $words[CURRENT] != -* ]]; then
            _vp_cache_commands && ret=0
            return ret
          fi

          case $words[2] in
            clean)
              _arguments \
                {-h,--help}"[Print help]" \
                && ret=0
              ;;

            *)
              _arguments \
                {-h,--help}"[Print help]" \
                '1:cache command:_vp_cache_commands' \
                && ret=0
              ;;
          esac
          ;;

        pack)
          _arguments \
            '--config-loader[Config loader to use]:loader:_vp_pack_config_loaders' \
            '--no-config[Disable config file]' \
            {-f,--format}"[Bundle format]:format:_vp_pack_formats" \
            '--clean[Clean output directory]' \
            '--no-clean[Do not clean the output directory]' \
            '*--deps.never-bundle[Mark dependency as external]:module' \
            '--minify[Minify output]' \
            '--devtools[Enable devtools integration]' \
            '--debug[Show debug logs]::feature' \
            '--target[Bundle target]:target' \
            {-l,--logLevel}"[Set log level]:level:_vp_log_levels" \
            '--fail-on-warn[Fail on warnings]' \
            '--no-write[Disable writing files to disk]' \
            {-d,--out-dir}"[Output directory]:dir:_directories" \
            '--treeshake[Tree-shake bundle]' \
            '--sourcemap[Generate source map]' \
            '--shims[Enable cjs and esm shims]' \
            '--platform[Target platform]:platform:_vp_pack_platforms' \
            '--dts[Generate dts files]' \
            '--publint[Enable publint]' \
            '--attw[Enable Are the Types Wrong integration]' \
            '--unused[Enable unused dependencies check]' \
            {-w,--watch}"[Watch mode]::path:_files" \
            '*--ignore-watch[Ignore path in watch mode]:path:_files' \
            '--from-vite[Reuse config from Vite or Vitest]::source:_vp_pack_sources' \
            '--report[Generate size report]' \
            '*--env.[Define compile-time env variable in the form NAME=VALUE]:name=value' \
            '--env-file[Load environment variables from a file]:file:_files' \
            '--env-prefix[Prefix for env variables injected into the bundle]:prefix' \
            '--on-success[Command to run on success]:command' \
            '*--copy[Copy files to the output directory]:path:_files' \
            '--public-dir[Alias for --copy]:dir:_directories' \
            '--tsconfig[Set tsconfig path]:tsconfig:_files' \
            '--unbundle[Enable unbundle mode]' \
            '--root[Root directory of input files]:dir:_directories' \
            '--exe[Bundle as executable]' \
            {-W,--workspace}"[Enable workspace mode]::dir:_directories" \
            '*'{-F,--filter}"[Filter configs by cwd or name]:pattern" \
            '--exports[Generate export-related metadata for package.json]' \
            {-h,--help}"[Display this message]" \
            '*:file:_files' \
            && ret=0
          ;;

        mcp)
          _arguments \
            $command_help_flags \
            && ret=0
          ;;

        help)
          _arguments \
            $command_help_flags \
            '1:vp command:_vp_help_commands' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_vp "$*"

