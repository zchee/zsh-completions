_vp_lint_rule_names() {
  local output rules

  if (( ${#_vp_lint_rule_cache[@]} )); then
    print -rl -- ${_vp_lint_rule_cache[@]}
    return 0
  fi

  output=$(vp lint --rules 2>/dev/null)
  [[ -n $output ]] || output=$(oxlint --rules 2>/dev/null)
  [[ -n $output ]] || return 1

  rules=$(print -r -- "$output" | awk -F'|' '
    /^\|/ {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2)
      if ($2 != "" && $2 != "Rule name" && $2 !~ /^-+$/) print $2
    }
  ' | sort -u)
  [[ -n $rules ]] || return 1

  _vp_lint_rule_cache=("${(@f)rules}")
  print -rl -- ${_vp_lint_rule_cache[@]}
}

_vp_lint_rule_or_category() {
  local -a categories values rules

  categories=(correctness suspicious pedantic perf style restriction nursery all)
  rules=(${(f)"$(_vp_lint_rule_names 2>/dev/null)"})
  values=($categories $rules)

  _values 'rule or category' $values
}

