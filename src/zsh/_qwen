_qwen__message() {
  _message "${1:-value}"
}

_qwen__prompt_text() {
  _qwen__message 'prompt text'
}

# Rebuild $words/$CURRENT after consuming $1 leading words so a nested
# _arguments can complete a subcommand leaf as if it were the command line.
_qwen__shift_words() {
  local shift_count=$1
  local -a shifted
  local index

  shifted=()
  for (( index = shift_count + 1; index <= ${#words}; index++ )); do
    shifted+=("${words[index]}")
  done

  reply=("${shifted[@]}")
  REPLY=$(( CURRENT - shift_count ))
  (( REPLY < 1 )) && REPLY=1
}

