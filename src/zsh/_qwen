    '(-s --sandbox)'{-s,--sandbox}'[run in sandbox]'
    '--sandbox-image=[sandbox image URI (deprecated)]:image:_qwen__message'
    '(-y --yolo)'{-y,--yolo}'[automatically accept all actions (YOLO mode)]'
    '--approval-mode=[set the approval mode]:mode:_qwen__approval_modes'
    '--acp[start the agent in ACP mode]'
    '--experimental-lsp[enable experimental LSP feature]'
    '--channel=[channel identifier]:channel:_qwen__channels'
    '*--allowed-mcp-server-names=[allowed MCP server names]:name:_qwen__message'
    '--mcp-config=[MCP server configuration as JSON string or file path]:config:_files'
    '*--allowed-tools=[tools to allow, bypassing confirmation]:tool:_qwen__message'
    '(-e --extensions)'{-e,--extensions}'=[list of extensions to use]:extension:_qwen__message'
    '(-l --list-extensions)'{-l,--list-extensions}'[list all available extensions and exit]'
    '*'{--include-directories,--add-dir}'=[additional directories to include in the workspace]:directory:_files -/'
    '--openai-logging[enable logging of OpenAI API calls]'
    '--openai-logging-dir=[custom directory for OpenAI API logs]:directory:_files -/'
    '--openai-api-key=[OpenAI API key]:key:_qwen__message'
    '--openai-base-url=[OpenAI base URL for custom endpoints]:url:_qwen__message'
    '--screen-reader[enable screen reader mode for accessibility]'
    '--input-format=[format consumed from standard input]:format:_qwen__input_formats'
    '(-o --output-format)'{-o,--output-format}'=[format of the CLI output]:format:_qwen__output_formats'
    '--include-partial-messages[include partial assistant messages (stream-json)]'
    '--json-fd=[file descriptor for structured JSON event output]:fd:_qwen__message'
    '--json-file=[file path for structured JSON event output]:file:_files'
    '--json-schema=[JSON Schema the final output must conform to]:schema:_qwen__message'
    '--input-file=[file path for receiving remote input commands]:file:_files'
    '(-c --continue)'{-c,--continue}'[resume the most recent session for the project]'
    '(-r --resume)'{-r,--resume}'=[resume a specific session by ID]::session id:_qwen__message'
    '--session-id=[specify a session ID for this run]:session id:_qwen__message'
    '--fork-session[create a new forked session from the resumed session]'
    '--worktree=[start the session inside a git worktree]::slug:_qwen__message'
