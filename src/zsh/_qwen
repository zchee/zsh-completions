# -- mcp ----------------------------------------------------------------------

_qwen__mcp_commands() {
  local -a commands
  commands=(
    'add:add a server'
    'remove:remove a server'
    'list:list all configured MCP servers'
    'reconnect:reconnect MCP server(s)'
    'approve:approve a gated MCP server'
    'reject:reject a gated MCP server'
  )
  _describe 'mcp command' commands
}

_qwen__complete_mcp() {
  local curcontext="$curcontext" state line ret=1
  typeset -A opt_args
  local -a specs
  _qwen__global_option_specs
  specs=("${reply[@]}")

  _arguments -C -s \
    ${specs[@]} \
    '1:mcp command:->command' \
    '*::mcp argument:->args' && ret=0

  case $state in
    command)
      _qwen__mcp_commands && ret=0
      ;;
    args)
      case $words[1] in
        add)
          _qwen__shift_words 1
          words=("${reply[@]}")
          CURRENT=$REPLY
          _arguments -s \
            ${specs[@]} \
            '(-s --scope)'{-s,--scope}'[configuration scope]:scope:_qwen__scopes' \
            '(-t --transport)'{-t,--transport}'[transport type]:transport:_qwen__mcp_transports' \
            '*'{-e,--env}'[set environment variables (KEY=value)]:env:_qwen__message' \
            '*'{-H,--header}'[set HTTP headers for SSE/HTTP transports]:header:_qwen__message' \
            '--timeout=[connection timeout in milliseconds]:milliseconds:_qwen__message' \
            '--trust[trust the server (bypass tool call confirmations)]' \
            '--description=[set the description for the server]:description:_qwen__message' \
            '--include-tools=[comma-separated list of tools to include]:tools:_qwen__message' \
            '--exclude-tools=[comma-separated list of tools to exclude]:tools:_qwen__message' \
            '--oauth-client-id=[OAuth client ID]:client id:_qwen__message' \
            '--oauth-client-secret=[OAuth client secret]:client secret:_qwen__message' \
            '--oauth-redirect-uri=[OAuth redirect URI]:uri:_qwen__message' \
            '--oauth-authorization-url=[OAuth authorization URL]:url:_qwen__message' \
            '--oauth-token-url=[OAuth token URL]:url:_qwen__message' \
            '--oauth-scopes=[OAuth scopes (comma-separated)]:scopes:_qwen__message' \
            '1:server name:_qwen__message' \
            '2:command or URL:_qwen__message' \
            '*::server argument:_normal' && ret=0
          ;;
        remove)
          _qwen__shift_words 1
          words=("${reply[@]}")
          CURRENT=$REPLY
          _arguments -s \
            ${specs[@]} \
            '1:server name:_qwen__message' && ret=0
          ;;
        reconnect|approve|reject)
          _qwen__shift_words 1
          words=("${reply[@]}")
          CURRENT=$REPLY
          _arguments -s \
            ${specs[@]} \
            '::server name:_qwen__message' && ret=0
          ;;
        list)
          _qwen__shift_words 1
          words=("${reply[@]}")
          CURRENT=$REPLY
          _arguments -s ${specs[@]} && ret=0
          ;;
      esac
      ;;
  esac
  return ret
}

