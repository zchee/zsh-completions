    '*--disabled-slash-commands=[slash command names to hide/disable]:command:_qwen__message'
    '--auth-type=[authentication type]:type:_qwen__auth_types'
    '(-v --version)'{-v,--version}'[show version number]'
  )
}

function _qwen() {
  local curcontext="$curcontext" state line ret=1
  typeset -A opt_args
  local -a specs root_specs

  _qwen__global_option_specs
  specs=("${reply[@]}")
  _qwen__root_option_specs
  root_specs=("${reply[@]}")

  _arguments -C -s \
    ${specs[@]} \
    ${root_specs[@]} \
    '1:qwen command or query:->command' \
    '*::qwen argument:->args' && ret=0

  case $state in
    command)
      _qwen__top_commands && ret=0
      ;;
    args)
      case $words[1] in
        mcp)
          _qwen__complete_mcp && ret=0
          ;;
        extensions)
          _qwen__complete_extensions && ret=0
          ;;
        channel)
          _qwen__complete_channel && ret=0
          ;;
        sessions)
          _qwen__complete_sessions && ret=0
          ;;
        review)
          _qwen__complete_review && ret=0
          ;;
        serve)
          _qwen__complete_serve && ret=0
          ;;
        hooks|hook|auth)
          _qwen__complete_help_only_leaf && ret=0
          ;;
        *)
          _arguments -s \
            ${specs[@]} \
            ${root_specs[@]} \
            '*:query:_qwen__prompt_text' && ret=0
          ;;
      esac
      ;;
  esac
  return ret
}

_qwen "$@"

