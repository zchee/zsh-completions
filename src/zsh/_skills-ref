_skills-ref__commands() {
  local -a commands
  commands=(
    'read-properties:read and print skill properties as JSON'
    'to-prompt:generate <available_skills> XML for agent prompts'
    'validate:validate a skill directory'
  )

  _describe -t commands 'skills-ref command' commands
}

_skills-ref__skill_path() {
  setopt localoptions extendedglob

  _alternative \
    'skill-directories:skill directory:_path_files -/' \
    'skill-files:SKILL.md file:_path_files -g "(#i)skill.md(.)"'
}

_skills-ref__command_arguments() {
  local command=$1
  local curcontext="${curcontext%:*:*}:skills-ref-${command}:"
  local ret=1

  words=("${(@)words[2,-1]}")
  (( CURRENT-- ))

  case $command in
    validate)
      _arguments -C \
        '--help[show this message and exit]' \
        '1:skill path:_skills-ref__skill_path' \
        && ret=0
      ;;

    read-properties)
      _arguments -C \
        '--help[show this message and exit]' \
        '1:skill path:_skills-ref__skill_path' \
        && ret=0
      ;;

    to-prompt)
      _arguments -C \
        '--help[show this message and exit]' \
        '*:skill path:_skills-ref__skill_path' \
        && ret=0
      ;;

    *)
      _message -r 'skills-ref command'
      ;;
  esac

  return ret
}

function _skills-ref() {
  local curcontext="$curcontext" state line ret=1
  typeset -A opt_args

  if (( CURRENT > 2 )); then
    case $words[2] in
      read-properties|to-prompt|validate)
        _skills-ref__command_arguments $words[2]
        return
        ;;
    esac
  fi

  _arguments -C \
    '--version[show the version and exit]' \
    '--help[show this message and exit]' \
    '1:command:_skills-ref__commands' \
    '*::argument:->argument' \
    && ret=0

  case $state in
    argument)
      case $words[2] in
        read-properties|to-prompt|validate)
          _skills-ref__command_arguments $words[2] && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_skills-ref "$*"

